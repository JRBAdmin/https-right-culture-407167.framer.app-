rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. Neural Memory
    function isValidNeuralMemory(data) {
      return data.keys().hasAll(['name', 'insight', 'timestamp']) &&
             data.name is string && data.name.size() <= 200 &&
             data.insight is string && data.insight.size() <= 50000 &&
             data.timestamp is timestamp;
    }

    match /neural_memory/{id} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidNeuralMemory(incoming()) && incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // 2. Family Data
    function isValidFamilyRecord(data) {
      return data.keys().hasAll(['memberName']) &&
             data.memberName is string && data.memberName.size() <= 200;
    }

    match /family_data/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidFamilyRecord(incoming());
    }

    // 3. Global Chat
    function isValidGlobalChat(data) {
      return data.keys().hasAll(['role', 'text', 'timestamp']) &&
             data.role in ['user', 'george'] &&
             data.text is string && data.text.size() <= 10000 &&
             data.timestamp is timestamp;
    }

    match /global_chat/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidGlobalChat(incoming()) && incoming().userId == request.auth.uid;
    }
  }
}
