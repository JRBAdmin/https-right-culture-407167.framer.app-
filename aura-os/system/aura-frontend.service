[Unit]
Description=Aura OS Electron Frontend
After=display-manager.service aura-core.service
Wants=aura-core.service

[Service]
Type=simple
User=aura
Display=:0
ExecStart=/opt/aura/frontend/aura-os
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment="DISPLAY=:0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus"

[Install]
WantedBy=graphical.target
